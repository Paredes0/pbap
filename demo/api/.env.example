# PBAP demo backend — operator-tunable knobs.
# Copy to `.env` next to server.py; the systemd unit and `uvicorn`
# both pick this up if you launch with `set -a; source .env; set +a; uvicorn ...`.

# --- Pipeline integration ---------------------------------------------------
# Absolute path to the cloned pbap repo on this host. The orchestrator will
# be invoked as `<repo>/scripts/run_audit.py`. Replace <USER> with your
# Linux username (or use ${HOME}/... — shell-expanded when you `source .env`).
PBAP_REPO_ROOT=${HOME}/pbap

# micromamba env that has the orchestrator's 5 deps (pandas, numpy, pyyaml,
# openpyxl, requests). Must NOT be any of the per-tool envs — those are
# activated automatically by audit_lib/tool_runner.py via `micromamba run`.
PBAP_RUN_ENV=ml

# Absolute path to the `micromamba` binary, OR just "micromamba" if it is
# already on the PATH inherited by this backend process. systemd and
# uvicorn-via-SSH do NOT inherit ~/.bashrc, so if micromamba lives under
# ~/bin or ~/.local/bin you MUST set the absolute path here.
# Run `which micromamba` (or `ls ~/bin/micromamba`) on the host to find it.
PBAP_MICROMAMBA_BIN=micromamba

# Backend → subprocess(micromamba run -n ml run_audit.py) → subprocess(
# micromamba run -n <tool_env> ...). The INNER call lives in
# audit_lib/tool_runner.py and uses bare "micromamba", so PATH must
# contain it for the whole subprocess tree. Uncomment and adjust to the
# directory that holds the micromamba binary on this host.
# PATH=${HOME}/bin:${PATH}

# Hard kill for a single job (seconds). 10 minutes is generous for 50 peptides
# across the 10 active tools on a modest GPU.
PBAP_RUN_TIMEOUT=600

# Where per-job working dirs live. Each job creates a UUID subfolder with
# its input FASTA and output. The janitor prunes finished jobs after
# JANITOR_JOB_TTL_SECONDS. Pick a path on a disk with enough room for
# a few dozen REPORT.html files (each is ~1–3 MB).
PBAP_JOBS_DIR=${HOME}/pbap_demo_jobs

# --- Demo limits ------------------------------------------------------------
# All optional; defaults match `demo/api/limits.py`.
MAX_PEPTIDES_PER_JOB=50
MIN_PEPTIDE_LEN=5
MAX_PEPTIDE_LEN=100
JOBS_PER_IP_PER_HOUR=3
DAILY_GLOBAL_JOB_CAP=200

# Tool allow-list. Comma-separated subset of the 10 active tools, or leave
# unset for all of them. Useful while testing a new tool to disable it
# without redeploying the frontend.
# ALLOWED_TOOLS=toxinpred3,antibp3,hemopi2,hemodl,deepb3p,deepbp,apex,perseucpp,acp_dpe,bertaip

# --- Concurrency ------------------------------------------------------------
# Bump to 2+ only if your host has enough VRAM for two PLM tools at once.
WORKER_COUNT=1

# --- Janitor ----------------------------------------------------------------
JANITOR_INTERVAL_SECONDS=3600
JANITOR_JOB_TTL_SECONDS=86400

# --- HTTP / proxy -----------------------------------------------------------
# If you're behind Cloudflare Tunnel, leave this on so the real client IP is
# used for rate limiting (instead of 127.0.0.1).
TRUST_PROXY_HEADERS=true

# Comma-separated allow-list for CORS. The Hugging Face Space's domain is
# the typical entry. Leave as `*` if the API is private to the Space anyway.
# ALLOWED_ORIGINS=https://<your-space>.hf.space

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO

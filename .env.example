# ============================================================================
# Peptide Bioactivity Audit Pipeline (PBAP) — environment variables
# ============================================================================
# Copy this file to .env and fill in the values that apply to your setup.
# .env itself is gitignored. Only this template is committed.
# ============================================================================

# --- micromamba installation root ------------------------------------------
# Path to your micromamba installation. The orchestrator uses this when
# resolving certain runtime LD_LIBRARY_PATH prepends (see
# audit_lib/tool_runner.py, ENV_RUNTIME_FLAGS). Leave commented to fall
# back to ~/micromamba.
#
# MICROMAMBA_ROOT_PREFIX=/home/youruser/micromamba

# --- SSH dispatch for CD-HIT (OPTIONAL) ------------------------------------
# Only relevant if you run the orchestrator on Windows and want to
# dispatch CD-HIT execution to a separate Linux node. If you run the
# pipeline entirely on Linux, leave these empty and ignore the
# ssh: block in config/pipeline_config.yaml.
#
# PBAP_SSH_HOST=your.host.tld
# PBAP_SSH_USER=youruser
# PBAP_CDHIT_BINARY=/usr/local/bin/cd-hit-2d
# PBAP_SSHFS_MOUNT_WIN=Z:/path/to/sshfs/mount
# PBAP_LINUX_BASE_PATH=/home/youruser/work/pipeline_Work

# --- Logging level ---------------------------------------------------------
# PBAP_LOG_LEVEL=INFO
